# ===========================================
# SUSpicious Totem - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no Git!

# --- Banco de Dados ---
DATABASE_URL=sqlite:///./suspicious.db

# --- Ambiente ---
# "development" usa MockPrinter e MockEsusGateway
# "production" usa EscPosPrinter e EsusGateway reais
ENVIRONMENT=development

# --- Impressora ---
# "mock" = imprime no terminal (dev)
# "escpos" = impressora real via USB (produção)
PRINTER_MODE=mock

# --- Integração e-SUS PEC ---
# URL da instância do PEC (deve ser HTTPS em produção)
ESUS_API_URL=https://localhost:443
# Credenciais geradas no PEC (menu Transmissão de Dados → Credenciais para API)
ESUS_API_USER=
ESUS_API_PASSWORD=
